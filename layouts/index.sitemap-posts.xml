{{- $site := .Site -}}
{{- $pages := slice $site.Home -}}

{{- with $site.GetPage "/page/about" -}}
  {{- $pages = $pages | append . -}}
{{- end -}}

{{- $featuredPaths := slice
  "/post/codes/golang/go的原子操作"
  "/post/codes/golang/理解sync.once"
  "/post/codes/golang/关于Golang切片的几个注意点"
  "/post/codes/python/python包组织的最佳实践"
  "/post/tech/blog/hugo的lastmod更新问题"
-}}

{{- range $featuredPaths -}}
  {{- with $site.GetPage . -}}
    {{- $pages = $pages | append . -}}
  {{- end -}}
{{- end -}}

{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {{- range $pages }}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{- if not .Lastmod.IsZero }}
    <lastmod>{{ .Lastmod.Format "2006-01-02T15:04:05-07:00" }}</lastmod>
    {{- end }}
  </url>
  {{- end }}
</urlset>
